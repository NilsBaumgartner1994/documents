# ── Settings you need to configure ───────────────────────────────────────────

# E-mail address used for Let's Encrypt certificate notifications
ACME_EMAIL=your-email@example.com

# The public domain where Paperless-ngx will be reachable (no https:// prefix).
# For local-only use (no public domain) set this to "localhost" and follow the
# "Running locally" instructions in README.md.
DOMAIN=paperless.example.com

# Django secret key – generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET=change-me-to-a-long-random-string

# rclone OAuth token for Google Drive sync.
# Run 'rclone config' on your LOCAL machine, create a remote named "gdrive"
# (type: drive), complete the OAuth flow, then copy the "token = …" line from
# ~/.config/rclone/rclone.conf and paste the JSON value here:
RCLONE_TOKEN={"access_token":"YOUR_ACCESS_TOKEN","token_type":"Bearer","refresh_token":"YOUR_REFRESH_TOKEN","expiry":"2099-01-01T00:00:00.000000000Z"}

# ── Paperless admin account ───────────────────────────────────────────────────
# The admin user is created (or updated) automatically on every startup.
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_MAIL=admin@example.com
PAPERLESS_ADMIN_PASSWORD=change-me-to-a-strong-admin-password

# ── Advanced / rarely changed settings ───────────────────────────────────────

# Your server timezone (used by Paperless-ngx)
TZ=Europe/Berlin

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
# Strong random password for the database user
PAPERLESS_DBPASS=change-me-to-a-strong-password

# ── File ownership inside containers ─────────────────────────────────────────
# Match the UID/GID of the user that owns files on the host (run: id -u / id -g)
USERMAP_UID=1000
USERMAP_GID=1000

# ── rclone / Google Drive sync ────────────────────────────────────────────────
# Name of the rclone remote as defined in rclone/rclone.conf  (default: gdrive)
RCLONE_REMOTE=gdrive

# Destination folder path inside Google Drive
RCLONE_DEST_PATH=paperless-backup

# How often to sync, in seconds (default: 3600 = every hour)
SYNC_INTERVAL_SECONDS=3600

# Backend type (keep "drive" for Google Drive)
RCLONE_TYPE=drive

# Access scope: "drive" = full access, "drive.readonly" = read only
RCLONE_SCOPE=drive
