# ── General ───────────────────────────────────────────────────────────────────
# Your server timezone (used by Paperless-ngx)
TZ=Europe/Berlin

# ── Traefik / Let's Encrypt ────────────────────────────────────────────────────
# E-mail address used for Let's Encrypt certificate notifications
ACME_EMAIL=your-email@example.com

# ── Paperless-ngx ─────────────────────────────────────────────────────────────
# The public domain where Paperless-ngx will be reachable (no https:// prefix)
PAPERLESS_DOMAIN=paperless.example.com

# Django secret key – generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
PAPERLESS_SECRET_KEY=change-me-to-a-long-random-string

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
# Strong random password for the database user
PAPERLESS_DBPASS=change-me-to-a-strong-password

# ── File ownership inside containers ──────────────────────────────────────────
# Match the UID/GID of the user that owns files on the host (run: id -u / id -g)
USERMAP_UID=1000
USERMAP_GID=1000

# ── rclone / Google Drive sync ────────────────────────────────────────────────
# Name of the rclone remote as defined in rclone/rclone.conf  (default: gdrive)
RCLONE_REMOTE=gdrive

# Destination folder path inside Google Drive (the folder that will be synced to).
# Use a plain folder name (e.g. "paperless-backup") for a top-level folder, or
# a slash-separated path (e.g. "backups/paperless") for a nested folder.
# The folder is created automatically if it does not exist.
RCLONE_DEST_PATH=paperless-backup

# How often to sync, in seconds (default: 3600 = every hour)
SYNC_INTERVAL_SECONDS=3600

# ── rclone credentials (used to generate rclone.conf automatically) ───────────
# Option A – OAuth (personal Google account)
# Run 'rclone config' on your LOCAL machine, choose Google Drive, complete the
# OAuth flow in the browser, then copy the resulting values below.

# Backend type (keep "drive" for Google Drive)
RCLONE_TYPE=drive

# OAuth client ID / secret – leave empty to use rclone's built-in OAuth app
# (easiest for personal Google accounts – no extra setup needed).
#
# Only fill these in if you want to use YOUR OWN Google Cloud OAuth app, e.g.
# to avoid rate limits or to meet corporate policies.  Steps to create one:
#   1. Open https://console.cloud.google.com/apis/credentials
#   2. Create a project (or select an existing one)
#   3. Enable the Google Drive API:
#      https://console.cloud.google.com/apis/library/drive.googleapis.com
#   4. Click "Create Credentials" → "OAuth client ID"
#   5. Choose "Desktop app" as the application type
#   6. Copy the generated "Client ID" and "Client Secret" here.
#   7. Run 'rclone config' on your LOCAL machine and enter those values when
#      prompted for client_id / client_secret to obtain the RCLONE_TOKEN below.
RCLONE_CLIENT_ID=
RCLONE_CLIENT_SECRET=

# Access scope: "drive" = full access, "drive.readonly" = read only
RCLONE_SCOPE=drive

# Token JSON from 'rclone config' (copy the value of the "token" key):
RCLONE_TOKEN={"access_token":"YOUR_ACCESS_TOKEN","token_type":"Bearer","refresh_token":"YOUR_REFRESH_TOKEN","expiry":"2099-01-01T00:00:00.000000000Z"}

# Option B – Service Account (Google Workspace / automated server setup)
# Leave RCLONE_TOKEN empty and set this to the in-container path of your JSON key:
# RCLONE_SERVICE_ACCOUNT_FILE=/config/rclone/service-account.json
