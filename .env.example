# ── Quick Start: fill in these values first ───────────────────────────────────
GH_TOKEN=XXX                # Create at: https://github.com/settings/tokens (classic or fine-grained, no scopes needed)
COPILOT_MODEL=gpt-4o        # Options: claude-3.5-sonnet (200K ctx), claude-3.7-sonnet (200K ctx), gpt-4o (64K ctx), o3-mini (200K ctx)
PAPERLESS_AI_TOKEN=XXX      # Paperless-ngx admin → /admin/authtoken/tokenproxy/ → Create token, or Settings → API → Create token
RCLONE_TOKEN=XXX            # Run 'rclone config' locally (Google Drive), then copy the "token" JSON value
RCLONE_CLIENT_ID=XXX        # Create OAuth 2.0 Desktop credentials in Google Cloud Console: https://rclone.org/drive/#making-your-own-client-id
RCLONE_CLIENT_SECRET=XXX    # Create OAuth 2.0 Desktop credentials in Google Cloud Console: https://rclone.org/drive/#making-your-own-client-id

# ── General ───────────────────────────────────────────────────────────────────
# Your server timezone (used by Paperless-ngx)
TZ=Europe/Berlin

# ── Traefik / Let's Encrypt ────────────────────────────────────────────────────
# By default, Traefik serves HTTPS with a self-signed certificate (works for
# localhost). For production with automatic Let's Encrypt TLS, see the README.
#ACME_EMAIL=your-email@example.com

# ── Paperless-ngx ─────────────────────────────────────────────────────────────
# The domain where Paperless-ngx will be reachable (no scheme prefix).
# For local use keep "localhost"; for production set your real domain.
PAPERLESS_DOMAIN=localhost

# Full URL of Paperless-ngx (used internally by Django).
# Local: http://localhost   Production: https://paperless.example.com
PAPERLESS_URL=http://localhost

# Django secret key – used internally by Django for sessions and hashing.
# ⚠️  This is NOT the Paperless-AI API Token! (see PAPERLESS_AI_TOKEN below)
# Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
PAPERLESS_SECRET_KEY=change-me-to-a-long-random-string

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
# Strong random password for the database user
PAPERLESS_DBPASS=change-me-to-a-strong-password

# ── File ownership inside containers ──────────────────────────────────────────
# Match the UID/GID of the user that owns files on the host (run: id -u / id -g)
USERMAP_UID=1000
USERMAP_GID=1000

# ── rclone / Google Drive sync ────────────────────────────────────────────────
# Name of the rclone remote as defined in rclone/rclone.conf  (default: gdrive)
RCLONE_REMOTE=gdrive

# Destination folder path inside Google Drive
RCLONE_DEST_PATH=paperless-backup

# How often to sync, in seconds (default: 3600 = every hour)
SYNC_INTERVAL_SECONDS=3600

# ── rclone credentials (used to generate rclone.conf automatically) ───────────
# Option A – OAuth (personal Google account)
# Run 'rclone config' on your LOCAL machine, choose Google Drive, complete the
# OAuth flow in the browser, then copy the resulting values below.

# Backend type (keep "drive" for Google Drive)
RCLONE_TYPE=drive

# Access scope: "drive" = full access, "drive.readonly" = read only
RCLONE_SCOPE=drive

# Token JSON from 'rclone config' (copy the value of the "token" key):
RCLONE_TOKEN={"access_token":"YOUR_ACCESS_TOKEN","token_type":"Bearer","refresh_token":"YOUR_REFRESH_TOKEN","expiry":"2099-01-01T00:00:00.000000000Z"}

# IMPORTANT: rclone's built-in OAuth credentials can be restricted by Google,
# causing "unauthorized_client" errors on token refresh (especially after a
# container restart).  It is strongly recommended to create your own OAuth
# client ID/secret and generate the token with those credentials.
# Guide: https://rclone.org/drive/#making-your-own-client-id
#
# Steps:
#   1. Create OAuth 2.0 Desktop credentials in Google Cloud Console
#   2. Run: rclone config  (enter your client_id and client_secret when prompted)
#   3. Copy the resulting token value into RCLONE_TOKEN above
#   4. Uncomment and fill in the two lines below:
#RCLONE_CLIENT_ID=your-client-id.apps.googleusercontent.com
#RCLONE_CLIENT_SECRET=your-client-secret

# ── Paperless-AI ──────────────────────────────────────────────────────────────
# Paperless-AI token – this is NOT the same as PAPERLESS_SECRET_KEY above!
# Create one in the Paperless-ngx admin UI after your first login:
#   Django Admin → /admin/authtoken/tokenproxy/ → Create token for your user
# Or via the Paperless-ngx web UI: Settings → API → Create token
PAPERLESS_AI_TOKEN=change-me-to-your-paperless-api-token

# ── GitHub Copilot API (default AI backend) ───────────────────────────────────
# Personal access token for a GitHub account with an active Copilot subscription.
# Create one at: https://github.com/settings/tokens
# Required scopes: none (classic token works; fine-grained token also works)
GH_TOKEN=change-me-to-your-github-token

# Copilot model forwarded to the API (default: claude-3.5-sonnet, 200K context).
# claude-3.5-sonnet  – 200 K context  ✅ handles large documents
# claude-3.7-sonnet  – 200 K context  (latest Sonnet)
# gpt-4o             –  64 K context  ⚠️  fails on large scans
# o3-mini            – 200 K context
# Run `docker compose exec copilot-api node /app/dist/index.js --help`
# or check /v1/models on the running service for the full list.
#COPILOT_MODEL=claude-3.5-sonnet

