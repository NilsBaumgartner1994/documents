# rclone/rclone.conf.example
#
# ─────────────────────────────────────────────────────────────────────────────
# NOTE: You no longer need to create rclone.conf manually.
# The rclone-config init container generates it automatically at every startup
# from the variables in your .env file.  See .env.example for the full list of
# variables (RCLONE_TYPE, RCLONE_TOKEN, …).
#
# This file is kept only as a reference so you know what the generated config
# will look like.
# ─────────────────────────────────────────────────────────────────────────────
#
# OAuth (personal Google account)
# ─────────────────────────────────────────────────────────────────────────────
# How to obtain the token:
#   1. Install rclone on your LOCAL machine: https://rclone.org/install/
#   2. Run:  rclone config
#   3. Choose: n (new remote) → name it "gdrive"
#   4. Choose type: drive
#   5. Choose scope: drive (full access) or drive.readonly
#   6. Complete the OAuth flow in the browser
#   7. Copy the "token" value from ~/.config/rclone/rclone.conf into
#      RCLONE_TOKEN in your .env file.
#
# Generated result:
#
# [gdrive]
# type = drive
# scope = drive
# token = {"access_token":"…","token_type":"Bearer","refresh_token":"…","expiry":"…"}
