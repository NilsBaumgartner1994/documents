# rclone/rclone.conf.example
#
# ─────────────────────────────────────────────────────────────────────────────
# NOTE: You do NOT need to create or edit rclone.conf manually.
#
# Setup flow:
#   1. Set RCLONE_CLIENT_ID and RCLONE_CLIENT_SECRET in your .env file.
#   2. Run once:  docker compose run --rm rclone-auth
#      A browser window opens (or copy the printed URL).  After you authorize,
#      the OAuth token is saved automatically to the rclone-config Docker volume.
#   3. Start the stack:  docker compose up -d
#
# The token is stored in the Docker volume, not in .env.
# On every startup, rclone-config regenerates the base config and preserves
# the existing token from the volume automatically.
#
# This file is kept only as a reference showing what the generated config
# will look like.
# ─────────────────────────────────────────────────────────────────────────────
#
# [gdrive]
# type = drive
# client_id = your-client-id.apps.googleusercontent.com
# client_secret = your-client-secret
# scope = drive
# token = {"access_token":"…","token_type":"Bearer","refresh_token":"…","expiry":"…"}
